{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "pocketarc/laravel-integrations",
    "description": "Production-ready third-party integrations for Laravel. Credential management, API request logging, rate limiting, sync scheduling, OAuth2, and health monitoring.",
    "keywords": ["laravel", "integrations", "api", "oauth2", "sync", "webhooks"],
    "license": "MIT",
    "authors": [
        {
            "name": "Bruno Moreira",
            "email": "bruno.moreira@solmyr.com"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.2",
        "ext-mbstring": "*",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "spatie/laravel-data": "^4.0",
        "thecodingmachine/safe": "^3.3"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "captainhook/captainhook": "^5.28",
        "ergebnis/phpstan-rules": "^2.6",
        "korbeil/phpstan-generic-rules": "^2.0",
        "larastan/larastan": "^3",
        "laravel/pint": "^1.24",
        "orchestra/testbench": "^10.0|^11.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.0|^12.0",
        "shipmonk/phpstan-rules": "^4.1",
        "thecodingmachine/phpstan-safe-rule": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "Integrations\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Integrations\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Integrations\\IntegrationsServiceProvider"
            ]
        }
    },
    "suggest": {},
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
